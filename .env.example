APP_ENV=production
DEBUG=false
ENABLE_DOCS=false
LOG_LEVEL=INFO
API_V1_PREFIX=/v1
CORS_ORIGINS=["https://multishield.example.com"]
DATABASE_URL=postgresql+asyncpg://multishield:change-me@postgres:5432/multishield
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_REQUESTS_PER_MINUTE=120
ENTERPRISE_DASHBOARD_DAYS=30
POSTGRES_DB=multishield
POSTGRES_USER=multishield
POSTGRES_PASSWORD=change-me
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=alerts@example.com
SMTP_PASSWORD=change-me
SMTP_USE_TLS=true
NOTIFICATION_FROM_EMAIL=alerts@example.com
NOTIFICATION_RECIPIENTS=["moderation@example.com","security@example.com"]
RETRAINING_ARTIFACTS_DIR=./workspace/retraining